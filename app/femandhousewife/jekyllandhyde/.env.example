# Required
OPENAI_API_KEY=your_key_here

# Optional model choices
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EMBED_MODEL=text-embedding-3-large

# RAG source config (choose one)
# RAG_PDF_PATHS=/absolute/path/to/The Strange Case of DrJekyll and Mr. Hyde.pdf
# RAG_PDF_FOLDER=/absolute/path/to/folder/with/pdfs

# Optional retrieval tuning
RAG_TOP_K=5
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=50
RAG_MAX_OUTPUT_TOKENS=1024
RAG_TEMPERATURE=0.2
